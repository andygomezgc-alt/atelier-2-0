generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  chef_executive
  sous_chef
  viewer
}

enum RecipeState {
  draft
  in_test
  approved
}

enum MenuStyle {
  elegant
  rustic
  minimal
}

enum IdeaStatus {
  open
  in_chat
  archived
}

model Restaurant {
  id              String   @id @default(cuid())
  name            String
  identityLine    String?
  photoUrl        String?
  languageDefault String   @default("es")
  inviteCode      String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users         User[]
  ideas         Idea[]
  conversations Conversation[]
  recipes       Recipe[]
  menuFolders   MenuFolder[]
  auditLogs     AuditLog[]
}

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  name         String
  photoUrl     String?
  bio          String?
  role         Role    @default(viewer)
  languagePref String  @default("es")
  defaultModel String  @default("sonnet")
  tokenVersion Int     @default(0)

  restaurantId String?
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ideas           Idea[]
  conversations   Conversation[]
  recipes         Recipe[]         @relation("RecipeAuthor")
  approvedRecipes Recipe[]         @relation("RecipeApprovedBy")

  // Auth.js (NextAuth) relations — populated by the @auth/prisma-adapter
  accounts Account[]
  sessions Session[]

  auditLogs AuditLog[] @relation("AuditLogActor")

  @@index([restaurantId])
}

model Idea {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  text         String     @db.Text
  status       IdeaStatus @default(open)
  createdAt    DateTime   @default(now())

  conversation Conversation?

  @@index([restaurantId, createdAt])
}

model Conversation {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  ideaId       String?    @unique
  idea         Idea?      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  modelUsed    String
  createdAt    DateTime   @default(now())

  messages Message[]
  recipes  Recipe[]

  @@index([restaurantId, createdAt])
  @@index([authorId, createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  inputTokens  Int?
  outputTokens Int?
  cachedTokens Int?
  latencyMs    Int?

  @@index([conversationId, createdAt])
}

model Recipe {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  authorId     String
  author       User       @relation("RecipeAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  title       String
  version     Int    @default(1)
  contentJson Json

  state    RecipeState @default(draft)
  priority Boolean     @default(false)

  sourceConversationId String?
  sourceConversation   Conversation? @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  approvedById String?
  approvedBy   User?     @relation("RecipeApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menuItems MenuItem[]

  @@index([restaurantId, state])
  @@index([restaurantId, priority])
  @@index([restaurantId, title])
  @@index([restaurantId, deletedAt])
}

model MenuFolder {
  id                String     @id @default(cuid())
  restaurantId      String
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name              String
  season            String?
  presentationStyle MenuStyle  @default(elegant)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  items MenuItem[]

  @@index([restaurantId])
  @@index([restaurantId, updatedAt])
}

model MenuItem {
  id           String     @id @default(cuid())
  menuFolderId String
  menuFolder   MenuFolder @relation(fields: [menuFolderId], references: [id], onDelete: Cascade)
  recipeId     String
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  customName   String?
  customDesc   String?    @db.Text
  price        Int
  order        Int

  @@index([menuFolderId, order])
}

// ─────────── Auth.js (NextAuth) tables ───────────
// Required by @auth/prisma-adapter. We intentionally keep them in the same
// schema so a single migration owns the whole DB.

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id           String     @id @default(cuid())
  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  actorId      String?
  actor        User?      @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  action       String     // e.g. "staff_role_changed", "staff_removed", "invite_regenerated"
  targetType   String?    // e.g. "User"
  targetId     String?
  payload      Json?
  createdAt    DateTime   @default(now())

  @@index([restaurantId, createdAt])
  @@index([actorId, createdAt])
}
