# Postgres (Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/atelier_dev?sslmode=require

# Auth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Resend (magic link)
RESEND_API_KEY=re_xxx
RESEND_FROM=Atelier <noreply@example.com>

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx

# Vercel Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Mobile JWT (separate from NEXTAUTH_SECRET; in production MUST be different)
MOBILE_JWT_SECRET=replace-with-output-of-openssl-rand-base64-32

# Mobile (apps/mobile/.env, gets EXPO_PUBLIC_ prefix to be readable in JS bundle)
EXPO_PUBLIC_API_URL=http://localhost:3000
