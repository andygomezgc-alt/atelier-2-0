{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@atelier/shared": ["../../packages/shared/src/index.ts"],
      "@atelier/shared/*": ["../../packages/shared/src/*"],
      "@atelier/i18n": ["../../packages/i18n/src/index.ts"],
      "@atelier/i18n/*": ["../../packages/i18n/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
